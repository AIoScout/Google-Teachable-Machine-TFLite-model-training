{
  "name": "ESP32_P4_IMX219",
  "version": "1.0.0",
  "description": "IMX219 camera driver for ESP32-P4 with Arduino support",
  "keywords": "camera, imx219, esp32, esp32-p4, mipi, csi",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-repo/ESP32_P4_IMX219.git"
  },
  "authors": [
    {
      "name": "koil",
      "email": "unfliout@gmail.com",
      "maintainer": true
    }
  ],
  "license": "MIT",
  "homepage": "https://github.com/koilkl/ESP32_P4_IMX219",
  "frameworks": ["arduino"],
  "platforms": ["espressif32"],
  "headers": ["imx219.h", "jpeg_enc.h", "imx219_regs.h"],
  "dependencies": [
    {
      "name": "ESP32 Arduino Core",
      "version": ">=3.0.0"
    }
  ],
  "build": {
    "srcFilter": [
      "+<*.c>",
      "+<*.h>"
    ]
  }
}
